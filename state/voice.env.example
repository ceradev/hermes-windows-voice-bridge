# =============================================================================
# Hermes Windows Voice Bridge — Configuration
# =============================================================================
# Copy this file to 'state/voice.env' and fill in your real values.
# This file is loaded automatically by the bridge, tray, and desktop app.
# NEVER commit voice.env to git (it contains secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Hermes Webhook Connection
# -----------------------------------------------------------------------------
# URL of the webhook route on your Hermes VPS.
# Create the route on your VPS with: hermes webhook subscribe voice
HERMES_WEBHOOK_URL=http://YOUR_VPS_IP:8644/webhooks/voice

# Secret shared between this client and the Hermes gateway.
# Used to sign every POST with HMAC-SHA256.
# Get this from your VPS after creating the webhook route.
HERMES_WEBHOOK_SECRET=PASTE_THE_SECRET_FROM_VPS

# API token for Hermes client authentication (Authorization: Bearer).
# Leave empty if the VPS does not require token-based auth.
HERMES_API_TOKEN=

# -----------------------------------------------------------------------------
# Audio & Wake Word
# -----------------------------------------------------------------------------
# Whisper model size: tiny, base, small, medium, large-v1, large-v2, large-v3
# 'base' is fast and good enough for most cases. 'small' for better accuracy.
HERMES_STT_MODEL=base

# Language code for speech-to-text: es, en, fr, de, auto (leave empty for auto-detect)
HERMES_STT_LANGUAGE=es

# Comma-separated wake phrases that activate listening.
HERMES_WAKE_PHRASES=hermes,oye hermes,hey hermes

# Energy threshold for wake word detection (lower = more sensitive).
HERMES_WAKE_ENERGY=0.008

# RMS threshold for silence detection (stops recording when below this).
HERMES_SILENCE_RMS=0.008

# Microphone device index (leave empty for default).
# Run: python .\src\windows_hermes_voice.py --list-devices
# HERMES_MIC_DEVICE=

# -----------------------------------------------------------------------------
# Hotkey & Shortcuts
# -----------------------------------------------------------------------------
# Global hotkey to activate listening immediately.
# Format: modifiers+key (ctrl, alt, shift, win separated by +)
HERMES_HOTKEY=ctrl+shift+h

# -----------------------------------------------------------------------------
# Feedback (Audio confirmation when wake word/hotkey triggers)
# -----------------------------------------------------------------------------
# Mode: off | beep | voice | both
#   off   = silent
#   beep  = Windows beep only
#   voice = spoken "Escuchando" only
#   both  = beep + spoken (recommended)
HERMES_FEEDBACK_MODE=both

# Optional: hint for Windows SAPI5 voice name.
# Leave empty for default voice. Set to a substring of a voice name to select it.
# Examples: 'Microsoft Helena' (Spanish), 'Microsoft David' (English), 'en-US-GuyNeural'
HERMES_FEEDBACK_VOICE=

# -----------------------------------------------------------------------------
# Webhook Sync & Timing
# -----------------------------------------------------------------------------
# If 1, wait for Hermes to reply inline in the webhook HTTP response (shown + TTS in this app).
# If 0, fire-and-forget. External deliver (e.g. Discord on VPS) is optional.
HERMES_WEBHOOK_SYNC=1

# Timeout in seconds for the webhook POST (especially when sync=1).
# Increase if Hermes takes a long time to generate responses.
HERMES_WEBHOOK_TIMEOUT=120

# Block size for audio capture in seconds.
HERMES_BLOCK_SECONDS=0.25

# Maximum seconds to wait for a command after wake word.
HERMES_MAX_COMMAND_SECONDS=12.0

# Window size for wake word detection in seconds.
HERMES_WAKE_WINDOW_SECONDS=2.0

# Timeout for silence after starting to record.
HERMES_SILENCE_TIMEOUT_SECONDS=0.85

# -----------------------------------------------------------------------------
# Session Persistence (Authentication)
# -----------------------------------------------------------------------------
# If 1, session survives app restarts and Windows reboots.
# If 0, session is cleared on every shutdown.
HERMES_PERSIST_SESSION=1

# Optional: URL of your auth backend's token refresh endpoint.
# If set, the bridge will call this URL to refresh access tokens before expiry.
# Leave empty to use local-only session extension (no server call).
HERMES_AUTH_REFRESH_URL=

# Timeout in seconds for auth refresh HTTP calls.
HERMES_AUTH_TIMEOUT=10

# Optional: static header sent with every auth refresh request.
# Format: HeaderName: HeaderValue
HERMES_AUTH_HEADER=

# Optional: secret header name and value for auth refresh requests.
# Some backends expect: X-Api-Key: secret_value
HERMES_AUTH_SECRET_HEADER=

# Optional: secret value (sent in the header above).
HERMES_AUTH_SECRET=

# Local session extension TTL in hours (when no auth_refresh_url is set).
HERMES_AUTH_LOCAL_TTL_HOURS=24

# -----------------------------------------------------------------------------
# TTS (Text-to-Speech)
# -----------------------------------------------------------------------------
# If 1, enable text-to-speech for reading Hermes responses aloud.
HERMES_TTS_ENABLED=1

# -----------------------------------------------------------------------------
# Advanced / Debug
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
# HERMES_LOG_LEVEL=INFO
